{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AppSpawner",
  "version": "3.1.0",
  "identifier": "com.appspawner.app",

  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite"
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AppSpawner",
        "width": 1300,
        "height": 840,
        "minWidth": 920,
        "minHeight": 620,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#09090e",
        "visible": true,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; connect-src ipc: http://ipc.localhost"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {},
      "nsis": {
        "languages": ["Spanish"],
        "displayLanguageSelector": false
      }
    }
  },

  "plugins": {
    "single-instance": null
  }
}
