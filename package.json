{
  "name": "appspawner",
  "version": "3.2.0",
  "description": "Site-Specific Browser Manager",
  "main": "src/main/main.js",
  "scripts": {
    "dev":            "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build":          "vite build && electron-builder --config electron-builder.config.js",
    "build:win":      "vite build && electron-builder --win --config electron-builder.config.js",
    "build:mac":      "vite build && electron-builder --mac --config electron-builder.config.js",
    "build:linux":    "vite build && electron-builder --linux --config electron-builder.config.js",
    "build:dir":      "vite build && electron-builder --dir --config electron-builder.config.js",
    "generate-icons": "node scripts/generate-icons.js",
    "preview":        "vite preview"
  },
  "dependencies": {
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "lucide-react": "^0.462.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8",
    "wait-on": "^7.2.0"
  },
  "author": "AppSpawner",
  "license": "MIT"
}
